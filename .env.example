# Google
GOOGLE_SA_KEY_PATH=/etc/secrets/google-sa.json

# Vimeo
VIMEO_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Banco de dados
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/drive_vimeo
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@postgres:5432/drive_vimeo

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_CONCURRENCY=2
SCANNER_INTERVAL_MINUTES=5
INTEGRITY_CHECK_INTERVAL_MINUTES=2
VIMEO_MONITOR_INTERVAL_MINUTES=1

# Auth
JWT_SECRET=change-me-in-production-use-a-strong-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
